  <entry>
    <title>flask+gunicorn 独立日志配置</title>
    <url>/2021/01/28/flask-gunicorn-%E7%8B%AC%E7%AB%8B%E6%97%A5%E5%BF%97%E9%85%8D%E7%BD%AE/</url>
    <content><![CDATA[<p>app.py</p>
<figure class="highlight python"><table><tr><td class="code"><pre><span class="line"><span class="keyword">from</span> flask <span class="keyword">import</span> Flask, request</span><br><span class="line"><span class="keyword">from</span> logging <span class="keyword">import</span> Filter</span><br><span class="line"></span><br><span class="line">app = Flask(__name__)</span><br><span class="line"></span><br><span class="line"><span class="meta">@app.route(<span class="params"><span class="string">&#x27;/&#x27;</span></span>)</span></span><br><span class="line"><span class="function"><span class="keyword">def</span> <span class="title">test</span>():</span></span><br><span class="line">    app.logger.error(<span class="string">&#x27;test error&#x27;</span>)</span><br><span class="line">    app.logger.info(<span class="string">&#x27;test info&#x27;</span>)</span><br><span class="line">    <span class="keyword">return</span> <span class="string">&#x27;test&#x27;</span></span><br><span class="line"></span><br><span class="line"><span class="comment"># 自定义Filter，可以在日志中添加访问者IP地址</span></span><br><span class="line"><span class="class"><span class="keyword">class</span> <span class="title">IPFilter</span>(<span class="params">Filter</span>):</span></span><br><span class="line">    <span class="function"><span class="keyword">def</span> <span class="title">filter</span>(<span class="params">self, record</span>):</span></span><br><span class="line">        record.remote_addr = request.environ.get(<span class="string">&#x27;HTTP_X_REAL_IP&#x27;</span>) <span class="keyword">or</span> request.remote_addr</span><br><span class="line">        <span class="keyword">return</span> <span class="built_in">super</span>().<span class="built_in">filter</span>(record)</span><br><span class="line">ip_filter = IPFilter()</span><br><span class="line">app.logger.addFilter(ip_filter)</span><br><span class="line"></span><br><span class="line"></span><br><span class="line"><span class="keyword">if</span> __name__ == <span class="string">&quot;__main__&quot;</span>:</span><br><span class="line">    app.run()</span><br></pre></td></tr></table></figure>
<p>gunicorn.py</p>
<figure class="highlight python"><table><tr><td class="code"><pre><span class="line"><span class="keyword">import</span> logging.config</span><br><span class="line"></span><br><span class="line">LOGGING = &#123;</span><br><span class="line">    <span class="string">&#x27;version&#x27;</span>: <span class="number">1</span>,</span><br><span class="line">    <span class="string">&#x27;disable_existing_loggers&#x27;</span>: <span class="literal">True</span>,</span><br><span class="line">    <span class="string">&#x27;formatters&#x27;</span>: &#123;</span><br><span class="line">        <span class="string">&#x27;info_format&#x27;</span>: &#123;</span><br><span class="line">            <span class="string">&#x27;format&#x27;</span>: <span class="string">&#x27;[%(asctime)s] [%(levelname)s] [FROM IP: %(remote_addr)s] %(message)s&#x27;</span></span><br><span class="line">        &#125;, <span class="string">&#x27;error_format&#x27;</span>: &#123;</span><br><span class="line">            <span class="string">&#x27;format&#x27;</span>: <span class="string">&#x27;[%(asctime)s] [%(levelname)s] %(message)s&#x27;</span></span><br><span class="line">        &#125;</span><br><span class="line">    &#125;,</span><br><span class="line">    <span class="string">&#x27;handlers&#x27;</span>: &#123;</span><br><span class="line">        <span class="string">&#x27;error&#x27;</span>: &#123;</span><br><span class="line">            <span class="string">&#x27;level&#x27;</span>: <span class="string">&#x27;ERROR&#x27;</span>,</span><br><span class="line">            <span class="string">&#x27;class&#x27;</span>: <span class="string">&#x27;logging.FileHandler&#x27;</span>,</span><br><span class="line">            <span class="string">&#x27;formatter&#x27;</span>: <span class="string">&#x27;error_format&#x27;</span>,</span><br><span class="line">            <span class="string">&#x27;filename&#x27;</span>: <span class="string">&#x27;error.log&#x27;</span></span><br><span class="line">        &#125;,</span><br><span class="line">        <span class="string">&#x27;info&#x27;</span>: &#123;</span><br><span class="line">            <span class="string">&#x27;level&#x27;</span>: <span class="string">&#x27;INFO&#x27;</span>,</span><br><span class="line">            <span class="string">&#x27;class&#x27;</span>: <span class="string">&#x27;logging.FileHandler&#x27;</span>,</span><br><span class="line">            <span class="string">&#x27;formatter&#x27;</span>: <span class="string">&#x27;info_format&#x27;</span>,</span><br><span class="line">            <span class="string">&#x27;filename&#x27;</span>: <span class="string">&#x27;info.log&#x27;</span></span><br><span class="line">        &#125;</span><br><span class="line">    &#125;,</span><br><span class="line">    <span class="comment"># app指向flask应用</span></span><br><span class="line">    <span class="string">&#x27;loggers&#x27;</span>: &#123;</span><br><span class="line">        <span class="string">&#x27;app&#x27;</span>: &#123;</span><br><span class="line">            <span class="string">&#x27;handlers&#x27;</span>: [<span class="string">&#x27;info&#x27;</span>, <span class="string">&#x27;error&#x27;</span>],</span><br><span class="line">            <span class="string">&#x27;level&#x27;</span>: <span class="string">&#x27;INFO&#x27;</span>,</span><br><span class="line">            <span class="string">&#x27;propagate&#x27;</span>: <span class="literal">False</span>,</span><br><span class="line">        &#125;</span><br><span class="line">    &#125;,</span><br><span class="line">&#125;</span><br><span class="line"></span><br><span class="line">logging.config.dictConfig(LOGGING)</span><br></pre></td></tr></table></figure>
<p>运行：</p>
<figure class="highlight plain"><table><tr><td class="code"><pre><span class="line">gunicorn -c gunicorn.py app:app</span><br></pre></td></tr></table></figure>
<p>访问主页触发日志：</p>
<p><img src="/images/flask-log.png" alt="flask日志"></p>
]]></content>
      <categories>
        <category>python</category>
      </categories>
      <tags>
        <tag>flask</tag>
        <tag>gunicorn</tag>
      </tags>
  </entry>
  <entry>
    <title>zeek SumStats简单使用</title>
    <url>/2021/02/04/zeek-SumStats%E7%AE%80%E5%8D%95%E4%BD%BF%E7%94%A8/</url>
    <content><![CDATA[<figure class="highlight plain"><table><tr><td class="code"><pre><span class="line">@load base&#x2F;protocols&#x2F;http</span><br><span class="line">@load base&#x2F;frameworks&#x2F;sumstats</span><br><span class="line"></span><br><span class="line">export &#123;</span><br><span class="line">	# The length of POST bodies to extract.</span><br><span class="line">	const http_post_body_length &#x3D; 200 &amp;redef;</span><br><span class="line">&#125;</span><br><span class="line"></span><br><span class="line">redef record HTTP::Info +&#x3D; &#123;</span><br><span class="line">	postdata: string &amp;log &amp;optional;</span><br><span class="line">&#125;;</span><br><span class="line"></span><br><span class="line">event log_post_bodies(f: fa_file, data: string)</span><br><span class="line">&#123;</span><br><span class="line">	for ( cid in f$conns )</span><br><span class="line">	&#123;</span><br><span class="line">		local c: connection &#x3D; f$conns[cid];</span><br><span class="line">		if ( ! c$http?$postdata )</span><br><span class="line">			c$http$postdata &#x3D; &quot;&quot;;</span><br><span class="line"></span><br><span class="line">		# If we are already above the captured size here, just return.</span><br><span class="line">		if ( |c$http$postdata| &gt; http_post_body_length )</span><br><span class="line">			return;</span><br><span class="line"></span><br><span class="line">		c$http$postdata &#x3D; c$http$postdata + data;</span><br><span class="line">		if ( |c$http$postdata| &gt; http_post_body_length )</span><br><span class="line">		&#123;</span><br><span class="line">			c$http$postdata &#x3D; c$http$postdata[0:http_post_body_length] + &quot;...&quot;;</span><br><span class="line">		&#125;</span><br><span class="line">	&#125;</span><br><span class="line">&#125;</span><br><span class="line"></span><br><span class="line">event file_over_new_connection(f: fa_file, c: connection, is_orig: bool)</span><br><span class="line">&#123;</span><br><span class="line">	if ( is_orig &amp;&amp; c?$http &amp;&amp; c$http?$method &amp;&amp; c$http$method &#x3D;&#x3D; &quot;POST&quot; )</span><br><span class="line">	&#123;</span><br><span class="line">		Files::add_analyzer(f, Files::ANALYZER_DATA_EVENT, [$stream_event&#x3D;log_post_bodies]);</span><br><span class="line">	&#125;</span><br><span class="line">&#125;</span><br><span class="line"></span><br><span class="line">event zeek_init()</span><br><span class="line">&#123;</span><br><span class="line">	print &quot;Hello world&quot;;</span><br><span class="line">	local r1 &#x3D; SumStats::Reducer($stream&#x3D;&quot;godzilla_webshell_event&quot;, $apply&#x3D;set(SumStats::UNIQUE, SumStats::SUM));</span><br><span class="line">	SumStats::create([</span><br><span class="line">		$name&#x3D;&quot;godzilla_webshell_detect&quot;,</span><br><span class="line">		$threshold&#x3D;3.0, # 设置事件出现的次数阈值</span><br><span class="line">		$epoch&#x3D;10sec,  # 设置事件出现的时间间隔</span><br><span class="line">		$reducers&#x3D;set(r1),  # 设置reducer，这里使用了SUM和UNIQUE</span><br><span class="line">		$threshold_val(key: SumStats::Key, result: SumStats::Result) &#x3D; </span><br><span class="line">		&#123;</span><br><span class="line">			return result[&quot;godzilla_webshell_event&quot;]$sum;</span><br><span class="line">		&#125;,</span><br><span class="line">		$threshold_crossed(key: SumStats::Key, result: SumStats::Result) &#x3D; </span><br><span class="line">		&#123;</span><br><span class="line">			local r &#x3D; result[&quot;godzilla_webshell_event&quot;];</span><br><span class="line">            # 每一次保存在SumStats中的信息都在$unique_vals里</span><br><span class="line">			for (value in r$unique_vals)</span><br><span class="line">			&#123;</span><br><span class="line">				local observe_str_vector: vector of string &#x3D; split_string(value$str, &#x2F;\$_\$&#x2F;);</span><br><span class="line">				print observe_str_vector[0], observe_str_vector[1];</span><br><span class="line">                # 省略了对哥斯拉流量的判断</span><br><span class="line">			&#125;</span><br><span class="line">		&#125;</span><br><span class="line">	]);</span><br><span class="line">	</span><br><span class="line">&#125;</span><br><span class="line"></span><br><span class="line">event http_message_done(c: connection, is_orig: bool, stat: http_message_stat)</span><br><span class="line">&#123;</span><br><span class="line">  if ( c?$http &amp;&amp; c$http?$status_code &amp;&amp; c$http?$method )</span><br><span class="line">  &#123;</span><br><span class="line">    if ( c$http$status_code &#x3D;&#x3D; 200 &amp;&amp; c$http$method &#x3D;&#x3D; &quot;POST&quot; )</span><br><span class="line">    &#123;</span><br><span class="line">		local key_str: string &#x3D; c$http$uid + &quot;$_$&quot; + cat(c$id$orig_h) + &quot;$_$&quot; + cat(c$id$orig_p) + &quot;$_$&quot; + cat(c$http$status_code) + &quot;$_$&quot; + cat(c$id$resp_h)+ &quot;$_$&quot; + cat(c$id$resp_p) + &quot;$_$&quot; + c$http$uri;</span><br><span class="line">		local observe_str: string &#x3D; cat(c$http$ts) + &quot;$_$&quot; + c$http$postdata;</span><br><span class="line">		SumStats::observe(&quot;godzilla_webshell_event&quot;, SumStats::Key($str&#x3D;key_str), SumStats::Observation($str&#x3D;observe_str));</span><br><span class="line">	&#125;</span><br><span class="line">  &#125;</span><br><span class="line">&#125;</span><br></pre></td></tr></table></figure>
<p>使用数据包重放：<br><img src="/images/zeek-SumStats.png" alt="Zeek重放数据包打印出post body"></p>
<p>参考：</p>
<ol>
<li><a href="https://www.anquanke.com/post/id/224831">巧用Zeek在流量层狩猎哥斯拉Godzilla</a></li>
<li><a href="https://docs.zeek.org/en/v4.0.0-rc2/frameworks/sumstats.html">Zeek SumStats官方文档</a></li>
<li><a href="https://madneal.com/post/%E6%B5%81%E9%87%8F%E5%88%86%E6%9E%90%E7%9A%84%E7%91%9E%E5%A3%AB%E5%86%9B%E5%88%80--zeek/">网络安全分析的瑞士军刀–zeek</a> 主要参考了请求体post数据的添加</li>
</ol>
]]></content>
      <categories>
        <category>Zeek</category>
      </categories>
      <tags>
        <tag>Zeek</tag>
        <tag>SumStats</tag>
      </tags>
  </entry>
  <entry>
    <title>一些小技巧</title>
    <url>/2021/01/27/%E4%B8%80%E4%BA%9B%E5%B0%8F%E6%8A%80%E5%B7%A7/</url>
    <content><![CDATA[<h1 id="tar打包不带文件路径"><a href="#tar打包不带文件路径" class="headerlink" title="tar打包不带文件路径"></a>tar打包不带文件路径</h1><figure class="highlight plain"><table><tr><td class="code"><pre><span class="line">tar -cf filename -C dirname .</span><br></pre></td></tr></table></figure>
<h1 id="python3在内存中打包zip"><a href="#python3在内存中打包zip" class="headerlink" title="python3在内存中打包zip"></a>python3在内存中打包zip</h1><figure class="highlight python"><table><tr><td class="code"><pre><span class="line"><span class="comment"># !user/bin/env python3</span></span><br><span class="line"><span class="comment"># -*-coding : utf-8 -*-</span></span><br><span class="line"><span class="keyword">import</span> zipfile</span><br><span class="line"><span class="keyword">from</span> io <span class="keyword">import</span> BytesIO</span><br><span class="line"><span class="keyword">import</span> os</span><br><span class="line"></span><br><span class="line"></span><br><span class="line"><span class="class"><span class="keyword">class</span> <span class="title">InMemoryZIP</span>(<span class="params"><span class="built_in">object</span></span>):</span></span><br><span class="line"></span><br><span class="line">    <span class="function"><span class="keyword">def</span> <span class="title">__init__</span>(<span class="params">self</span>):</span></span><br><span class="line">        <span class="comment"># create the in-memory file-like object</span></span><br><span class="line">        self.in_memory_zip = BytesIO()</span><br><span class="line"></span><br><span class="line">    <span class="function"><span class="keyword">def</span> <span class="title">append</span>(<span class="params">self, filename_in_zip, file_contents</span>):</span></span><br><span class="line">        <span class="string">&quot;&quot;&quot; Appends a file with name filename_in_zip \</span></span><br><span class="line"><span class="string">        and contents of file_contents to the in-memory zip.</span></span><br><span class="line"><span class="string">        &quot;&quot;&quot;</span></span><br><span class="line">        <span class="comment"># create a handle to the in-memory zip in append mode</span></span><br><span class="line">        zf = zipfile.ZipFile(self.in_memory_zip, <span class="string">&#x27;a&#x27;</span>, zipfile.ZIP_DEFLATED, <span class="literal">False</span>)</span><br><span class="line"></span><br><span class="line">        <span class="comment"># write the file to the in-memory zip</span></span><br><span class="line">        zf.writestr(filename_in_zip, file_contents)</span><br><span class="line"></span><br><span class="line">        <span class="comment"># mark the files as having been created on Windows</span></span><br><span class="line">        <span class="comment"># so that Unix permissions are not inferred as 0000</span></span><br><span class="line">        <span class="keyword">for</span> zfile <span class="keyword">in</span> zf.filelist:</span><br><span class="line">            zfile.create_system = <span class="number">0</span></span><br><span class="line">        <span class="keyword">return</span> self</span><br><span class="line"></span><br><span class="line">    <span class="function"><span class="keyword">def</span> <span class="title">appendfile</span>(<span class="params">self, file_path, file_name=<span class="literal">None</span></span>):</span></span><br><span class="line">        <span class="string">&quot;&quot;&quot; Read a file with path file_path \</span></span><br><span class="line"><span class="string">        and append to in-memory zip with name file_name.</span></span><br><span class="line"><span class="string">        &quot;&quot;&quot;</span></span><br><span class="line">        <span class="keyword">if</span> file_name <span class="keyword">is</span> <span class="literal">None</span>:</span><br><span class="line">            file_name = os.path.split(file_path)[<span class="number">1</span>]</span><br><span class="line"></span><br><span class="line">        f = <span class="built_in">open</span>(file_path, <span class="string">&#x27;rb&#x27;</span>)</span><br><span class="line">        file_contents = f.read()</span><br><span class="line">        self.append(file_name, file_contents)</span><br><span class="line">        f.close()</span><br><span class="line">        <span class="keyword">return</span> self</span><br><span class="line"></span><br><span class="line">    <span class="function"><span class="keyword">def</span> <span class="title">read</span>(<span class="params">self</span>):</span></span><br><span class="line">        <span class="string">&quot;&quot;&quot; Returns a string with the contents of the in-memory zip.</span></span><br><span class="line"><span class="string">        &quot;&quot;&quot;</span></span><br><span class="line">        self.in_memory_zip.seek(<span class="number">0</span>)</span><br><span class="line">        <span class="keyword">return</span> self.in_memory_zip.read()</span><br><span class="line"></span><br><span class="line">    <span class="function"><span class="keyword">def</span> <span class="title">writetofile</span>(<span class="params">self, filename</span>):</span></span><br><span class="line">        <span class="string">&quot;&quot;&quot;</span></span><br><span class="line"><span class="string">        Write the in-memory zip to a file</span></span><br><span class="line"><span class="string">        &quot;&quot;&quot;</span></span><br><span class="line">        f = <span class="built_in">open</span>(filename, <span class="string">&#x27;wb&#x27;</span>)</span><br><span class="line">        f.write(self.read())</span><br><span class="line">        f.close()</span><br><span class="line"></span><br><span class="line"><span class="keyword">if</span> __name__ == <span class="string">&#x27;__main__&#x27;</span>:</span><br><span class="line">    imz = InMemoryZIP()</span><br><span class="line">    imz.appendfile(<span class="string">&#x27;a.txt&#x27;</span>).append(<span class="string">&#x27;test.txt&#x27;</span>, <span class="string">&#x27;This is content in test.txt&#x27;</span>)</span><br><span class="line">    imz.writetofile(<span class="string">&#x27;test.zip&#x27;</span>)</span><br></pre></td></tr></table></figure>]]></content>
      <categories>
        <category>存档</category>
      </categories>
      <tags>
        <tag>tricks</tag>
      </tags>
  </entry>
